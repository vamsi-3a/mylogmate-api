# ============================================================
# MyLogMate API — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_ENV=development          # development | production | test
DEBUG=true                   # Set false in production

# ── Database (PostgreSQL via Neon in prod, local docker in dev) ──
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mylogmate

# ── Redis (Redis Cloud in prod) ───────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant (Qdrant Cloud in prod) ─────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                        # Required in production (Qdrant Cloud API key)
QDRANT_COLLECTION=log_entries          # Collection name (default: log_entries)

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: make gen-secret
JWT_SECRET_KEY=your-jwt-secret-key-minimum-32-characters-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Refresh-token cookie ──────────────────────────────────────
# lax  = frontend + API share a registrable domain (same-site)
# none = frontend + API on different sites (Vercel + Render) — forces Secure
# In production with split Vercel/Render domains, set: COOKIE_SAMESITE=none
COOKIE_SAMESITE=lax

# ── Encryption (AES-256 via Fernet) ──────────────────────────
# Generate with: make gen-key
# THIS KEY DECRYPTS ALL USER LOG CONTENT — back it up securely!
ENCRYPTION_KEY=your-fernet-key-here

# ── Groq API (LLM — free tier) ───────────────────────────────
GROQ_API_KEY=your-groq-api-key-here
LLM_PROVIDER=groq              # groq | ollama

# ── Google OAuth 2.0 ─────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ── Gmail SMTP (password reset emails only) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password    # Use App Password, not account password

# ── CORS (comma-separated list of allowed origins) ───────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Rate Limiting ─────────────────────────────────────────────
AI_QUERY_DAILY_LIMIT=50        # Max AI queries per user per day
AUTH_RATE_LIMIT=5/minute       # Max auth attempts per IP per minute
